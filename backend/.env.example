NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://pft_user:pft_password@localhost:5432/pft?schema=public
JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_JWT_EXPIRES_IN=1h
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
ENABLE_CSRF=false
SMTP_FROM=no-reply@pft.example.com
APP_BASE_URL=http://localhost:5173
